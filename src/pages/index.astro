---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import SkillBadge from '../components/SkillBadge.astro';
import FormationCard from '../components/FormationCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactSection from '../components/ContactSection.astro';
import i18n from '../i18n/fr.json';
import cv from '../data/cv.json';
import { getCollection } from 'astro:content';

const formations = (await getCollection('formations')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const projects = (await getCollection('projects')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title={`${cv.personal.name} — ${cv.personal.title}`}
  description={cv.personal.tagline}
>
  <Hero />

  <!-- Experience -->
  <section class="section" id="experience">
    <div class="container">
      <SectionTitle title={i18n.sections.experience} number="01." />
      <div class="experience-list">
        {cv.experience.map((exp) => (
          <ExperienceCard
            company={exp.company}
            location={exp.location}
            roles={exp.roles}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Compétences -->
  <section class="section section--alt" id="skills">
    <div class="container">
      <SectionTitle title={i18n.sections.skills} number="02." />
      <div class="skills-layout animate-fade-up">
        <div class="skills-tier">
          <div class="skills-tier__header">
            <h3 class="skills-tier__title">Maîtrise avancée</h3>
            <span class="skills-tier__line"></span>
          </div>
          <div class="skills-tier__rows">
            {Object.entries(cv.skills.expert).map(([category, skills]) => (
              <div class="skills-row">
                <span class="skills-row__label">{category}</span>
                <div class="skills-row__badges">
                  {skills.map((skill) => (
                    <SkillBadge name={skill} tier="primary" />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="skills-tier">
          <div class="skills-tier__header">
            <h3 class="skills-tier__title">Compétent</h3>
            <span class="skills-tier__line"></span>
          </div>
          <div class="skills-tier__rows">
            {Object.entries(cv.skills.competent).map(([category, skills]) => (
              <div class="skills-row">
                <span class="skills-row__label">{category}</span>
                <div class="skills-row__badges">
                  {skills.map((skill) => (
                    <SkillBadge name={skill} tier="secondary" />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Formations -->
  <section class="section" id="formations">
    <div class="container">
      <SectionTitle title={i18n.sections.formations} number="03." />
      <div class="formations-grid">
        {formations.map((formation) => (
          <FormationCard
            title={formation.data.title}
            institution={formation.data.institution}
            type={formation.data.type}
            date={formation.data.date}
            description={formation.data.description}
            slug={formation.id}
            tags={formation.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Projets -->
  <section class="section section--alt" id="projects">
    <div class="container">
      <SectionTitle title={i18n.sections.projects} number="04." />
      <div class="projects-grid">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            slug={project.id}
            repo={project.data.repo}
            demo={project.data.demo}
          />
        ))}
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>

<style>
  .experience-list {
    max-width: 48rem;
  }

  .skills-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    max-width: 48rem;
  }

  .skills-tier__header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .skills-tier__title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-primary);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .skills-tier__line {
    flex: 1;
    height: 1px;
    background-color: var(--color-border);
  }

  .skills-tier__rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .skills-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
  }

  .skills-row__label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-transform: capitalize;
    min-width: 7rem;
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .skills-row__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  @media (max-width: 640px) {
    .skills-row {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .skills-row__label {
      min-width: unset;
    }
  }

  .formations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

</style>
