---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import SkillBadge from '../components/SkillBadge.astro';
import i18n from '../i18n/fr.json';
import cv from '../data/cv.json';
---

<BaseLayout
  title={`${cv.personal.name} — ${cv.personal.title}`}
  description={cv.personal.tagline}
>
  <Hero />

  <!-- Experience -->
  <section class="section" id="experience">
    <div class="container">
      <SectionTitle title={i18n.sections.experience} />
      <div class="experience-list">
        {cv.experience.map((exp) => (
          <ExperienceCard
            company={exp.company}
            location={exp.location}
            roles={exp.roles}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Compétences -->
  <section class="section section--alt" id="skills">
    <div class="container">
      <SectionTitle title={i18n.sections.skills} />
      <div class="skills-grid animate-fade-up">
        {Object.entries(cv.skills).map(([category, skills]) => (
          <div class="skills-group">
            <h3 class="skills-group__title">{category}</h3>
            <div class="skills-group__badges">
              {skills.map((skill) => (
                <SkillBadge name={skill} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .experience-list {
    max-width: 48rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-lg);
  }

  .skills-group {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .skills-group__title {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: capitalize;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .skills-group__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
</style>
