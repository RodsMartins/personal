---
import BaseLayout from '../../layouts/BaseLayout.astro';
import i18n from '../../i18n/fr.json';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={`${project.data.title} — Rodrigo`}
  description={project.data.description}
>
  <section class="section">
    <div class="container detail">
      <a href="/projets/" class="detail__back">← {i18n.labels.backToList}</a>

      <header class="detail__header animate-fade-up">
        <h1>{project.data.title}</h1>
        <p class="detail__meta">{project.data.date}</p>
        <div class="detail__tags">
          {project.data.tags.map((tag) => (
            <span class="detail__tag">{tag}</span>
          ))}
        </div>
        <div class="detail__links">
          {project.data.repo && (
            <a href={project.data.repo} target="_blank" rel="noopener noreferrer" class="detail__link">
              {i18n.labels.viewCode} ↗
            </a>
          )}
          {project.data.demo && (
            <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="detail__link detail__link--primary">
              {i18n.labels.viewProject} ↗
            </a>
          )}
        </div>
      </header>

      <article class="detail__content prose animate-fade-up delay-1">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .detail {
    max-width: 48rem;
  }

  .detail__back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    transition: color var(--transition);
  }

  .detail__back:hover {
    color: var(--color-accent);
  }

  .detail__header {
    margin-bottom: var(--space-xl);
  }

  .detail__meta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .detail__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .detail__tag {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    background-color: rgba(99, 102, 241, 0.1);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  .detail__links {
    display: flex;
    gap: var(--space-md);
  }

  .detail__link {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    transition: all var(--transition);
  }

  .detail__link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .detail__link--primary {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .detail__link--primary:hover {
    background-color: var(--color-accent-hover);
    color: #fff;
  }

  /* Prose styles for markdown content */
  .prose :global(h2) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .prose :global(h3) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .prose :global(p) {
    margin-bottom: var(--space-md);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .prose :global(li) {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
    list-style: disc;
  }

  .prose :global(strong) {
    color: var(--color-text-primary);
  }

  .prose :global(code) {
    font-size: 0.875em;
    background-color: rgba(99, 102, 241, 0.1);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
  }
</style>
