---
interface Props {
  name: string;
  tier?: 'primary' | 'secondary';
}

const { name, tier = 'secondary' } = Astro.props;
---

<span class:list={['skill-badge', `skill-badge--${tier}`]}>{name}</span>

<style>
  .skill-badge {
    display: inline-block;
    font-weight: 500;
    color: var(--color-accent);
    border-radius: 9999px;
    white-space: nowrap;
    transition: all var(--transition);
  }

  .skill-badge--primary {
    padding: 0.5rem 1.1rem;
    font-size: 0.9rem;
    color: var(--color-accent-on-card);
    background-color: rgba(74, 108, 247, 0.12);
    border: 1px solid rgba(74, 108, 247, 0.35);
  }

  .skill-badge--primary:hover {
    background-color: rgba(74, 108, 247, 0.2);
    border-color: rgba(74, 108, 247, 0.5);
  }

  .skill-badge--secondary {
    padding: 0.375rem 0.875rem;
    font-size: 0.8rem;
    background-color: rgba(74, 108, 247, 0.06);
    border: 1px solid rgba(74, 108, 247, 0.15);
    color: rgba(123, 154, 255, 0.8);
  }

  .skill-badge--secondary:hover {
    background-color: rgba(74, 108, 247, 0.1);
    border-color: rgba(74, 108, 247, 0.3);
    color: var(--color-accent);
  }
</style>
