---
import i18n from '../i18n/fr.json';

interface Props {
  title: string;
  institution: string;
  type: string;
  date: string;
  description: string;
  slug: string;
  tags?: string[];
}

const { title, institution, type, date, description, slug, tags = [] } = Astro.props;

const typeLabels: Record<string, string> = {
  diplome: 'Diplôme',
  certification: 'Certification',
  formation: 'Formation',
  mooc: 'MOOC',
};
---

<article class="formation-card animate-fade-up">
  <div class="formation-card__header">
    <span class="formation-card__type">{typeLabels[type] ?? type}</span>
    <span class="formation-card__date">{date}</span>
  </div>
  <h3 class="formation-card__title">
    <a href={`/formations/${slug}/`}>{title}</a>
  </h3>
  <p class="formation-card__institution">{institution}</p>
  <p class="formation-card__desc">{description}</p>
  {tags.length > 0 && (
    <div class="formation-card__tags">
      {tags.map((tag) => (
        <span class="formation-card__tag">{tag}</span>
      ))}
    </div>
  )}
  <a href={`/formations/${slug}/`} class="formation-card__more">
    {i18n.labels.viewMore} →
  </a>
</article>

<style>
  .formation-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    transition: all var(--transition);
  }

  .formation-card:hover {
    border-color: rgba(99, 102, 241, 0.3);
    transform: translateY(-2px);
  }

  .formation-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .formation-card__type {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background-color: rgba(99, 102, 241, 0.1);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  .formation-card__date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .formation-card__title {
    margin-bottom: var(--space-xs);
  }

  .formation-card__title a {
    color: var(--color-text-primary);
    transition: color var(--transition);
  }

  .formation-card__title a:hover {
    color: var(--color-accent);
  }

  .formation-card__institution {
    font-size: 0.9rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .formation-card__desc {
    font-size: 0.9rem;
    margin-bottom: var(--space-md);
  }

  .formation-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .formation-card__tag {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    background-color: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
  }

  .formation-card__more {
    font-size: 0.85rem;
    font-weight: 500;
  }
</style>
