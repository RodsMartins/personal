---
import i18n from '../i18n/fr.json';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://github.com/RodsMartins', label: 'GitHub', icon: 'github' },
  { href: 'https://www.linkedin.com/in/RodrigoSilvaMartins', label: 'LinkedIn', icon: 'linkedin' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__left">
      <p class="footer__copy">
        &copy; {currentYear} Rodrigo Martins. {i18n.footer.rights}
      </p>
      <p class="footer__built">
        {i18n.footer.builtWith} <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      </p>
    </div>

    <div class="footer__social">
      {socialLinks.map(({ href, label }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="footer__social-link">
          {label}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-lg);
    margin-top: auto;
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer__copy {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer__built {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .footer__social {
    display: flex;
    gap: var(--space-md);
  }

  .footer__social-link {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    transition: color var(--transition);
  }

  .footer__social-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
