---
import i18n from '../i18n/fr.json';

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: `${base}#experience`, label: i18n.nav.experience },
  { href: `${base}#skills`, label: i18n.nav.skills },
  { href: `${base}#formations`, label: i18n.nav.formations },
  { href: `${base}#projects`, label: i18n.nav.projects },
  { href: `${base}a-propos/`, label: i18n.nav.about },
];

const socialLinks = [
  { href: 'https://github.com/RodsMartins', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/RodrigoSilvaMartins', label: 'LinkedIn' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__nav">
      <h4 class="footer__heading">Navigation</h4>
      <ul class="footer__nav-list">
        {navLinks.map(({ href, label }) => (
          <li><a href={href} class="footer__nav-link">{label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__info">
      <h4 class="footer__heading">Rodrigo Martins</h4>
      <p class="footer__location">Prilly, Suisse</p>
      <p class="footer__copy">
        &copy; {currentYear} {i18n.footer.rights}
      </p>
      <p class="footer__built">
        {i18n.footer.builtWith} <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      </p>
    </div>

    <div class="footer__social">
      <h4 class="footer__heading">Liens</h4>
      {socialLinks.map(({ href, label }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" class="footer__social-link">
          {label}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-xl);
    margin-top: auto;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-xl);
  }

  .footer__heading {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__nav-link {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    transition: color var(--transition);
  }

  .footer__nav-link:hover {
    color: var(--color-accent);
  }

  .footer__info {
    text-align: center;
  }

  .footer__location {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .footer__copy {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
  }

  .footer__built {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .footer__social {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__social-link {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    transition: color var(--transition);
  }

  .footer__social-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-lg);
    }

    .footer__social {
      text-align: center;
    }
  }
</style>
