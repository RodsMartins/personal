---
import i18n from '../i18n/fr.json';
import cv from '../data/cv.json';
---

<section class="hero section">
  <div class="container hero__inner">
    <p class="hero__greeting animate-fade-up">{i18n.hero.greeting}</p>
    <h1 class="hero__name animate-fade-up delay-1 glow">{cv.personal.name}</h1>
    <p class="hero__title animate-fade-up delay-2">{cv.personal.title}</p>
    <p class="hero__tagline animate-fade-up delay-3">{cv.personal.tagline}</p>
    <div class="hero__actions animate-fade-up delay-4">
      <a href="#experience" class="hero__btn hero__btn--primary">
        {i18n.sections.experience}
      </a>
      <a href="/projets/" class="hero__btn hero__btn--secondary">
        {i18n.sections.projects}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
  }

  .hero__inner {
    max-width: 48rem;
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero__name {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .hero__title {
    font-size: clamp(1.25rem, 3vw, 2rem);
    color: var(--color-text-secondary);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .hero__tagline {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero__btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9rem;
    transition: all var(--transition);
  }

  .hero__btn--primary {
    background-color: var(--color-accent);
    color: #fff;
  }

  .hero__btn--primary:hover {
    background-color: var(--color-accent-hover);
    color: #fff;
  }

  .hero__btn--secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
  }

  .hero__btn--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
