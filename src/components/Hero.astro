---
import i18n from '../i18n/fr.json';
import cv from '../data/cv.json';
---

<section class="hero section">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="hero__greeting hero-animate hero-animate-1">{i18n.hero.greeting}</p>
      <h1 class="hero__name hero-animate hero-animate-2 glow">{cv.personal.name}<span class="hero__name-dot">.</span></h1>
      <p class="hero__title hero-animate hero-animate-3">{cv.personal.title}</p>
      <p class="hero__tagline hero-animate hero-animate-4">{cv.personal.tagline}</p>
      <div class="hero__actions hero-animate hero-animate-5">
        <a href="#experience" class="hero__btn hero__btn--primary">
          {i18n.sections.experience}
        </a>
        <a href={`mailto:${cv.personal.email}`} class="hero__btn hero__btn--secondary">
          {i18n.labels.contact}
        </a>
      </div>
    </div>
    <div class="hero__decoration hero-animate hero-animate-4" aria-hidden="true">
      <svg viewBox="0 0 200 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero__dot-grid">
        <!-- Grid dots -->
        <circle cx="20" cy="20" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="60" cy="20" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="100" cy="20" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="140" cy="20" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="180" cy="20" r="3" fill="var(--color-accent)" opacity="0.15"/>

        <circle cx="20" cy="60" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="60" cy="60" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="100" cy="60" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="140" cy="60" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="180" cy="60" r="3" fill="var(--color-accent)" opacity="0.15"/>

        <circle cx="20" cy="100" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="60" cy="100" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="100" cy="100" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="140" cy="100" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="180" cy="100" r="3" fill="var(--color-accent)" opacity="0.15"/>

        <circle cx="20" cy="140" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="60" cy="140" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="100" cy="140" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="140" cy="140" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="180" cy="140" r="3" fill="var(--color-accent)" opacity="0.15"/>

        <circle cx="20" cy="180" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="60" cy="180" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="100" cy="180" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="140" cy="180" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="180" cy="180" r="3" fill="var(--color-accent)" opacity="0.15"/>

        <circle cx="20" cy="220" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="60" cy="220" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="100" cy="220" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="140" cy="220" r="3" fill="var(--color-accent)" opacity="0.15"/>
        <circle cx="180" cy="220" r="3" fill="var(--color-accent)" opacity="0.15"/>

        <!-- Network connections -->
        <line x1="60" y1="60" x2="140" y2="100" stroke="var(--color-accent)" stroke-width="1" opacity="0.2"/>
        <line x1="140" y1="100" x2="100" y2="180" stroke="var(--color-accent)" stroke-width="1" opacity="0.2"/>
        <line x1="100" y1="180" x2="60" y2="140" stroke="var(--color-accent)" stroke-width="1" opacity="0.2"/>
        <line x1="60" y1="140" x2="60" y2="60" stroke="var(--color-accent)" stroke-width="1" opacity="0.15"/>

        <!-- Active nodes (network graph hint) -->
        <circle cx="60" cy="60" r="5" fill="var(--color-accent)" class="hero__node hero__node--1"/>
        <circle cx="140" cy="100" r="5" fill="var(--color-accent)" class="hero__node hero__node--2"/>
        <circle cx="100" cy="180" r="5" fill="var(--color-accent)" class="hero__node hero__node--3"/>
        <circle cx="60" cy="140" r="4" fill="var(--color-accent)" class="hero__node hero__node--4"/>
      </svg>
    </div>
  </div>
  <div class="hero__scroll-indicator hero-animate hero-animate-5" aria-hidden="true">
    <svg width="20" height="28" viewBox="0 0 20 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="1" y="1" width="18" height="26" rx="9" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
      <circle class="hero__scroll-dot" cx="10" cy="8" r="2" fill="currentColor" opacity="0.6"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    position: relative;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 0.6fr;
    align-items: center;
    gap: var(--space-xl);
  }

  .hero__content {
    max-width: 48rem;
  }

  .hero__decoration {
    position: relative;
    justify-self: center;
  }

  .hero__dot-grid {
    width: 100%;
    max-width: 200px;
    height: auto;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 70%);
  }

  @keyframes node-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.4); }
  }

  .hero__node {
    transform-origin: center;
    transform-box: fill-box;
  }

  .hero__node--1 { animation: node-pulse 3s ease-in-out infinite; }
  .hero__node--2 { animation: node-pulse 3s ease-in-out 0.8s infinite; }
  .hero__node--3 { animation: node-pulse 3s ease-in-out 1.6s infinite; }
  .hero__node--4 { animation: node-pulse 3s ease-in-out 2.4s infinite; }

  .hero__name-dot {
    color: var(--color-accent);
    animation: dot-pulse 1s ease 0.5s both;
  }

  @keyframes dot-pulse {
    0% { opacity: 0; transform: scale(0); }
    50% { transform: scale(1.3); }
    100% { opacity: 1; transform: scale(1); }
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero__name {
    font-size: clamp(3rem, 9vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .hero__title {
    font-size: clamp(1.25rem, 3vw, 2rem);
    color: var(--color-text-secondary);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .hero__tagline {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero__btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9rem;
    transition: all var(--transition);
  }

  .hero__btn--primary {
    background-color: var(--color-accent);
    color: #fff;
  }

  .hero__btn--primary:hover {
    background-color: var(--color-accent-hover);
    color: #fff;
  }

  .hero__btn--secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
  }

  .hero__btn--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-text-secondary);
  }

  .hero__scroll-dot {
    animation: scroll-bounce 1.5s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__decoration {
      display: none;
    }
  }
</style>
