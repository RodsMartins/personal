---
import i18n from '../i18n/fr.json';

interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  repo?: string;
  demo?: string;
}

const { title, description, tags, slug, repo, demo } = Astro.props;
---

<article class="project-card animate-fade-up">
  <div class="project-card__content">
    <h3 class="project-card__title">
      <a href={`${import.meta.env.BASE_URL}projets/${slug}/`}>{title}</a>
    </h3>
    <p class="project-card__desc">{description}</p>
    <div class="project-card__tags">
      {tags.map((tag) => (
        <span class="project-card__tag">{tag}</span>
      ))}
    </div>
    <div class="project-card__links">
      {repo && (
        <a href={repo} target="_blank" rel="noopener noreferrer" class="project-card__link">
          {i18n.labels.viewCode}
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" rel="noopener noreferrer" class="project-card__link">
          {i18n.labels.viewProject}
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    transition: all var(--transition);
  }

  .project-card:hover {
    border-color: rgba(74, 108, 247, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .project-card__title {
    margin-bottom: var(--space-sm);
  }

  .project-card__title a {
    color: var(--color-text-primary);
    transition: color var(--transition);
  }

  .project-card__title a:hover {
    color: var(--color-accent);
  }

  .project-card__desc {
    font-size: 0.9rem;
    margin-bottom: var(--space-md);
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .project-card__tag {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-accent-on-card);
    background-color: rgba(74, 108, 247, 0.1);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  .project-card__links {
    display: flex;
    gap: var(--space-md);
  }

  .project-card__link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color var(--transition);
  }

  .project-card__link:hover {
    color: var(--color-accent);
  }
</style>
