---
import i18n from '../i18n/fr.json';

interface Role {
  title: string;
  project: string;
  startDate: string;
  endDate: string | null;
  description: string;
  highlights: string[];
  tech: string[];
}

interface Props {
  company: string;
  location: string;
  roles: Role[];
}

const { company, location, roles } = Astro.props;

function formatDate(dateStr: string): string {
  const [year, month] = dateStr.split('-');
  const months = ['Janv.', 'Fév.', 'Mars', 'Avr.', 'Mai', 'Juin', 'Juil.', 'Août', 'Sept.', 'Oct.', 'Nov.', 'Déc.'];
  return `${months[parseInt(month) - 1]} ${year}`;
}
---

<article class="xp-company animate-fade-up">
  <div class="xp-company__header">
    <div>
      <h3 class="xp-company__name">{company}</h3>
      <p class="xp-company__location">{location}</p>
    </div>
    <p class="xp-company__narrative">6+ ans d'évolution — du stage au Full-Stack & Chef de projet</p>
  </div>

  <div class="xp-company__roles">
    {roles.map((role, index) => (
      <div class="xp-role">
        <div class="xp-role__timeline" aria-hidden="true">
          <div class:list={['xp-role__dot', { 'xp-role__dot--current': index === 0 }]}></div>
          {index < roles.length - 1 && <div class="xp-role__line"></div>}
        </div>
        <div class="xp-role__content">
          <div class="xp-role__header">
            <h4 class="xp-role__title">{role.title}</h4>
            <p class="xp-role__project">{role.project}</p>
            <p class="xp-role__date">
              {formatDate(role.startDate)} — {role.endDate ? formatDate(role.endDate) : <span class="xp-role__present">{i18n.labels.present}</span>}
            </p>
          </div>
          <p class="xp-role__desc">{role.description}</p>
          {role.highlights.length > 0 && (
            <ul class="xp-role__highlights">
              {role.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          )}
          {role.tech.length > 0 && (
            <div class="xp-role__tech">
              {role.tech.map((t) => (
                <span class="xp-role__tech-badge">{t}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</article>

<style>
  .xp-company {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .xp-company__header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .xp-company__name {
    font-size: 1.5rem;
    margin-bottom: var(--space-xs);
  }

  .xp-company__location {
    font-size: 0.9rem;
    color: var(--color-accent-on-card);
  }

  .xp-company__narrative {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: #71717a;
    max-width: 22rem;
    text-align: right;
  }

  .xp-role {
    display: flex;
    gap: var(--space-lg);
  }

  .xp-role__timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .xp-role__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 6px;
    opacity: 0.5;
  }

  .xp-role__dot--current {
    opacity: 1;
    box-shadow: 0 0 8px var(--color-accent-glow);
  }

  .xp-role__line {
    width: 2px;
    flex: 1;
    margin-top: var(--space-sm);
    background: linear-gradient(to bottom, var(--color-accent), var(--color-border));
  }

  .xp-role__content {
    padding-bottom: var(--space-xl);
  }

  .xp-role:last-child .xp-role__content {
    padding-bottom: 0;
  }

  .xp-role__title {
    font-size: 1.15rem;
    margin-bottom: var(--space-xs);
  }

  .xp-role__project {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: var(--space-xs);
  }

  .xp-role__date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .xp-role__present {
    color: var(--color-success);
    font-weight: 600;
  }

  .xp-role__desc {
    margin-bottom: var(--space-md);
  }

  .xp-role__highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .xp-role__highlights li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .xp-role__highlights li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .xp-role__tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .xp-role__tech-badge {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-accent-on-card);
    background-color: rgba(74, 108, 247, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
  }

  @media (max-width: 768px) {
    .xp-role {
      gap: var(--space-md);
    }

    .xp-company {
      padding: var(--space-md);
    }

    .xp-company__header {
      flex-direction: column;
    }

    .xp-company__narrative {
      text-align: left;
    }
  }
</style>
