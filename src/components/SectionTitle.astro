---
interface Props {
  title: string;
  id?: string;
  number?: string;
}

const { title, id, number } = Astro.props;
---

<div class="section-title" id={id} data-section-title>
  <h2 class="section-title__text">
    {number && <span class="section-title__number">{number}</span>}
    {title}
  </h2>
  <div class="section-title__line" aria-hidden="true"></div>
</div>

<script>
  document.querySelectorAll('[data-section-title]').forEach((title) => {
    const section = title.closest('section');
    if (!section) return;
    section.addEventListener('mouseenter', () => title.classList.add('is-hovered'));
    section.addEventListener('mouseleave', () => title.classList.remove('is-hovered'));
  });
</script>

<style>
  .section-title {
    margin-bottom: var(--space-xl);
  }

  .section-title__text {
    display: inline-block;
    margin-bottom: var(--space-sm);
  }

  .section-title__number {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-accent);
    margin-right: var(--space-sm);
    font-weight: 500;
    display: inline-block;
    transition: transform var(--transition);
  }

  .section-title__line {
    width: 3rem;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
    transition: width var(--transition);
  }

  .section-title:hover .section-title__number,
  .section-title.is-hovered .section-title__number {
    transform: translateX(-4px);
  }

  .section-title:hover .section-title__line,
  .section-title.is-hovered .section-title__line {
    width: 5rem;
  }
</style>
